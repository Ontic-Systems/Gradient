// no_std smoke fixture: control flow
//
// Issue #347 — every fn here must classify into the `core` tier:
// no `!{Heap}`, `!{IO}`, `!{FS}`, `!{Net}`, `!{Time}`, `!{Mut}` in
// the inferred effect closure. Out-of-axis effects (`!{Stack}`) are
// orthogonal and allowed. Recursion stays on stack — no Heap.
//
// Coverage per ADR 0005 #347 acceptance:
//   "Fixtures cover: ..., control flow, ..."
//
// Post-#348: this fixture is also a smoke for the `@no_std` checker
// rejection.

@no_std

fn abs_int(n: Int) -> !{Stack} Int:
    if n >= 0:
        n
    else:
        0 - n

fn max_int(a: Int, b: Int) -> !{Stack} Int:
    if a >= b:
        a
    else:
        b

fn min_int(a: Int, b: Int) -> !{Stack} Int:
    if a <= b:
        a
    else:
        b

fn clamp_int(value: Int, lo: Int, hi: Int) -> !{Stack} Int:
    if value < lo:
        lo
    else:
        if value > hi:
            hi
        else:
            value

fn sign_int(n: Int) -> !{Stack} Int:
    if n > 0:
        1
    else:
        if n < 0:
            0 - 1
        else:
            0

fn factorial(n: Int) -> !{Stack} Int:
    if n <= 1:
        1
    else:
        n * factorial(n - 1)

fn fibonacci(n: Int) -> !{Stack} Int:
    if n <= 1:
        n
    else:
        fibonacci(n - 1) + fibonacci(n - 2)

fn pow_int(base: Int, exponent: Int) -> !{Stack} Int:
    if exponent <= 0:
        1
    else:
        base * pow_int(base, exponent - 1)

fn is_even(n: Int) -> !{Stack} Bool:
    if n == 0:
        true
    else:
        if n == 1:
            false
        else:
            if n > 0:
                is_even(n - 2)
            else:
                is_even(n + 2)

fn gcd(a: Int, b: Int) -> !{Stack} Int:
    if b == 0:
        a
    else:
        gcd(b, a - (a / b) * b)
