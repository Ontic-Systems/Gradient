fn neg_compare_logic(a: Int, b: Int, c: Int) -> Bool:
    let p1 = a > 0
    let p2 = b > 0
    let p3 = c > 0
    let n1 = not p1
    let n2 = not p2
    let n3 = not p3
    let mixed1 = p1 and n2 and p3
    let mixed2 = n1 or p2 or n3
    let mixed3 = mixed1 and mixed2
    ret mixed3 or n1

fn negation_truth_dispatch(a: Int, b: Int, c: Int) -> Int:
    let r1 = neg_compare_logic(a, b, c)
    let r2 = neg_compare_logic(b, c, a)
    let r3 = neg_compare_logic(c, a, b)
    let n1 = not r1
    let n2 = not r2
    let n3 = not r3
    let all_neg = n1 and n2 and n3
    let any_neg = n1 or n2 or n3
    if all_neg:
        ret -3
    else:
        if any_neg:
            if n1:
                ret -1
            else:
                if n2:
                    ret -2
                else:
                    ret -3
        else:
            ret 0

fn compare_negate_chain(a: Int, b: Int) -> Bool:
    let lt = a < b
    let eq = a == b
    let gt = a > b
    let n_lt = not lt
    let n_eq = not eq
    let n_gt = not gt
    let consistent = n_lt and n_eq or n_gt
    let mixed = lt and not gt or eq and n_lt
    ret consistent and mixed or eq

fn negation_truth_logic_driver(a: Int, b: Int, c: Int) -> Int:
    let r1 = negation_truth_dispatch(a, b, c)
    let r2 = negation_truth_dispatch(c, b, a)
    let r3 = compare_negate_chain(a, b)
    let r4 = compare_negate_chain(b, c)
    let s1 = if r3:
        1
    else:
        0
    let s2 = if r4:
        2
    else:
        0
    ret r1 + r2 + s1 + s2
