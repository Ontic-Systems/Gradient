fn mba_classify(a: Int, b: Int, c: Int) -> Int:
    let big = a > b
    let sum_ok = (a + b) > c
    let prod_ok = (a * b) >= c
    let any_ok = sum_ok or prod_ok
    if big and sum_ok:
        ret 1
    else:
        if big or any_ok:
            ret 2
        else:
            if sum_ok and prod_ok:
                ret 3
            else:
                ret 0

fn mba_score(a: Int, b: Int) -> Int:
    let positive = a > 0
    let larger = a > b
    let combo = positive and larger
    let altcombo = (not positive) or (a == b)
    if combo:
        ret a - b
    else:
        if altcombo:
            ret b - a
        else:
            ret 0

fn mixed_bool_arith_compare_driver(a: Int, b: Int, c: Int) -> Int:
    let cls = mba_classify(a, b, c)
    let sc = mba_score(a, b)
    ret cls + sc
