fn lt_chain(a: Int, b: Int, c: Int) -> Bool:
    let ab = a < b
    let bc = b < c
    let ac = a < c
    let trans = ab and bc
    if trans:
        ret ac
    else:
        ret true

fn le_chain(a: Int, b: Int, c: Int, d: Int) -> Bool:
    let ab = a <= b
    let bc = b <= c
    let cd = c <= d
    let ad = a <= d
    let middle = ab and bc and cd
    if middle:
        ret ad
    else:
        ret true

fn eq_chain(a: Int, b: Int, c: Int) -> Bool:
    let ab = a == b
    let bc = b == c
    let ac = a == c
    let same = ab and bc
    if same:
        ret ac
    else:
        ret true

fn ordering_branch(a: Int, b: Int, c: Int) -> Int:
    let lt = a < b and b < c
    let eq = a == b and b == c
    if lt:
        ret 1
    else:
        if eq:
            ret 0
        else:
            ret -1
