// Slot 104 — 7-function mutual-recursion cycle (widest yet, beating slot 67's 6-fn).
// Stresses: deeper mutual recursion termination via decreasing argument.

fn r1(n: Int) -> Int:
    if n <= 0:
        0
    else:
        r2(n - 1)

fn r2(n: Int) -> Int:
    if n <= 0:
        0
    else:
        r3(n - 1) + 1

fn r3(n: Int) -> Int:
    if n <= 0:
        0
    else:
        r4(n - 1)

fn r4(n: Int) -> Int:
    if n <= 0:
        0
    else:
        r5(n - 1) + 1

fn r5(n: Int) -> Int:
    if n <= 0:
        0
    else:
        r6(n - 1)

fn r6(n: Int) -> Int:
    if n <= 0:
        0
    else:
        r7(n - 1) + 1

fn r7(n: Int) -> Int:
    if n <= 0:
        0
    else:
        r1(n - 1)

fn main(n: Int) -> Int:
    r1(n)
