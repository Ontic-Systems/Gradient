// Slot 166 — Long arith chain captured in deep lets feeding dispatch.
// Stresses: 8-term arith chain captured into nested lets, then 4-branch dispatch.

fn arith_grow(n: Int) -> Int:
    let s1 = n + 1 - 2 + 3 - 4 + 5 - 6 + 7
    let s2 = s1 - n + n - n + n - n + n - n
    let s3 = s2 + s1 - s2 + s1 - s2 + s1 - s2 + s1
    let s4 = s3 + s2 - s3 + s2 - s3 + s2 - s3 + s2
    s4

fn dispatch(k: Int) -> Int:
    let g = arith_grow(k)
    if g > 100:
        if g > 200:
            g + 1
        else:
            g - 1
    else:
        if g < 0:
            0 - g
        else:
            g

fn main() -> Int:
    dispatch(7)
