// Slot 180 — Twenty-three-function mutual-recursion cycle.
// Stresses: widest mutual recursion, extending slot 175's 22-function cycle.

fn r1(n: Int) -> Int:
    if n <= 0:
        n
    else:
        r2(n - 1) + 1

