    if n <= 0:
        n
    else:
        u6(n - 1) + 5

fn u6(n: Int) -> Int:
    if n <= 0:
        n
    else:
        u7(n - 1) + 6

fn u7(n: Int) -> Int:
    if n <= 0:
        n
    else:
        u8(n - 1) + 7

