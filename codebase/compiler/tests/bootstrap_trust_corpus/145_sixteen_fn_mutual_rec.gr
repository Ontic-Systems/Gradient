fn u15(n: Int) -> Int:
    if n <= 0:
        n
    else:
        u16(n - 1) + 15

fn u16(n: Int) -> Int:
    if n <= 0:
        n
    else:
        u1(n - 1) + 16

fn main() -> Int:
    u1(16)
