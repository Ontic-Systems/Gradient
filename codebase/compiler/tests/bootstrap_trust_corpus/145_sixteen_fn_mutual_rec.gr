// Slot 145 — Sixteen-function mutual-recursion cycle.
// Stresses: widest mutual recursion so far, extending slot 140's 15-function cycle.

fn u1(n: Int) -> Int:
    if n <= 0:
        n
    else:
        u2(n - 1) + 1

fn u2(n: Int) -> Int:
    if n <= 0:
        n
    else:
        u3(n - 1) + 2

fn u3(n: Int) -> Int:
    if n <= 0:
        n
    else:
        u4(n - 1) + 3

