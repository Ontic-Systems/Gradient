// Slot 162 — Full and/or chain with negations and 6-comparison reduction.
// Stresses: wide and/or with not, 6 comparisons, two-branch payload.

fn check(a: Int, b: Int, c: Int, d: Int, e: Int, f: Int) -> Int:
    let p1 = a < b
    let p2 = b < c
    let p3 = c < d
    let p4 = d < e
    let p5 = e < f
    let p6 = a < f
    let strict = p1 and p2 and p3 and p4 and p5 and p6
    let q1 = a == b
    let q2 = c == d
    let q3 = e == f
    let any_eq = q1 or q2 or q3
    let not_strict = not strict
    let combined = strict and (not any_eq)
    if combined:
        a + b + c + d + e + f
    else:
        if not_strict and any_eq:
            a - b + c - d + e - f
        else:
            0

fn main() -> Int:
    check(1, 2, 3, 4, 5, 6)
