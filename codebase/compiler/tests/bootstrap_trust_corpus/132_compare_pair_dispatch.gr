// Slot 132 — Paired-comparison dispatch via and/or reductions.
// Stresses: 2-pair compares feeding 4-branch if-tree returning distinct ints per quadrant.

fn pair_class(a: Int, b: Int, c: Int, d: Int) -> Int:
    let lhs_eq = a == b
    let rhs_eq = c == d
    let lhs_lt = a < b
    let rhs_lt = c < d
    let both_eq = lhs_eq and rhs_eq
    let lhs_eq_rhs_lt = lhs_eq and rhs_lt
    let lhs_lt_rhs_eq = lhs_lt and rhs_eq
    if both_eq:
        0
    else:
        if lhs_eq_rhs_lt:
            1
        else:
            if lhs_lt_rhs_eq:
                2
            else:
                if lhs_lt or rhs_lt:
                    3
                else:
                    4

fn main(a: Int, b: Int, c: Int, d: Int) -> Int:
    pair_class(a, b, c, d)
