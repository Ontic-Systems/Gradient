// Slot 155 — Eighteen-function mutual-recursion cycle.
// Stresses: widest mutual recursion so far, extending slot 150's 17-function cycle.

fn w1(n: Int) -> Int:
    if n <= 0:
        n
    else:
        w2(n - 1) + 1

fn w2(n: Int) -> Int:
    if n <= 0:
        n
    else:
        w3(n - 1) + 2

fn w3(n: Int) -> Int:
    if n <= 0:
        n
    else:
        w4(n - 1) + 3

