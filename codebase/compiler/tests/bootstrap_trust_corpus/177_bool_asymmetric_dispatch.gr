// Slot 177 — Bool and/or asymmetric truth dispatch.
// Stresses: combinations of and/or with negations producing distinct
// integer payloads via 6-branch dispatch.

fn classify_bool_pair(a: Bool, b: Bool, c: Bool) -> Int:
    if a and b and c:
        7
    else:
        if a and b:
            6
        else:
            if a and c:
                5
            else:
                if b and c:
                    4
                else:
                    if a or b or c:
                        3
                    else:
                        0

fn negation_swap(a: Bool, b: Bool) -> Int:
    let na = not a
    let nb = not b
    if na and nb:
        1
    else:
        if a or b:
            2
        else:
            0

fn dispatch(x: Int, y: Int) -> Int:
    let p = x > 0
    let q = y > 0
    let r = x + y > 0
    let cls = classify_bool_pair(p, q, r)
    let neg = negation_swap(p, q)
    if cls == 0:
        neg
    else:
        cls + neg

fn main() -> Int:
    dispatch(5, -3) + dispatch(-1, -2)
