fn add_pair(a: Int, b: Int) -> Int:
    ret a + b

fn add_triple(a: Int, b: Int, c: Int) -> Int:
    ret a + b + c

fn add_five(a: Int, b: Int, c: Int, d: Int, e: Int) -> Int:
    ret a + b + c + d + e

fn calls_inside_branches(a: Int, b: Int) -> Int:
    if a > b:
        let x = add_pair(a, b)
        let y = add_triple(a, b, x)
        ret y
    else:
        if a < b:
            let z = add_pair(b, a)
            let w = add_five(a, b, z, a, b)
            ret w
        else:
            ret add_pair(a, a)

fn recursive_branch_calls(n: Int) -> Int:
    if n <= 0:
        ret 0
    else:
        if n == 1:
            ret add_pair(1, recursive_branch_calls(n - 1))
        else:
            if n == 2:
                ret add_triple(1, 2, recursive_branch_calls(n - 1))
            else:
                let inner = recursive_branch_calls(n - 1)
                ret add_five(n, n - 1, inner, 1, 2)

fn calls_in_branches_driver(a: Int, b: Int) -> Int:
    let r1 = calls_inside_branches(a, b)
    let r2 = calls_inside_branches(b, a)
    let r3 = recursive_branch_calls(a)
    ret r1 + r2 + r3
