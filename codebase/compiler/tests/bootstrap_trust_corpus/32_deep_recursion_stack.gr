fn countdown(n: Int) -> Int:
    if n <= 0:
        ret 0
    else:
        ret 1 + countdown(n - 1)

fn ackermann_lite(m: Int, n: Int) -> Int:
    if m <= 0:
        ret n + 1
    else:
        if n <= 0:
            ret m
        else:
            ret m + n

fn deep_call(n: Int) -> Int:
    let r = countdown(n)
    ret r

fn driver(start: Int) -> Int:
    let a = countdown(start)
    let b = deep_call(start)
    ret a + b
