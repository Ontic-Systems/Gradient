// Slot 175 — Twenty-two-function mutual-recursion cycle.
// Stresses: widest mutual recursion, extending slot 170's 21-function cycle.

fn q1(n: Int) -> Int:
    if n <= 0:
        n
    else:
        q2(n - 1) + 1

