// Slot 165 — Twenty-function mutual-recursion cycle.
// Stresses: widest mutual recursion so far, extending slot 160's 19-function cycle.

fn y1(n: Int) -> Int:
    if n <= 0:
        n
    else:
        y2(n - 1) + 1

fn y2(n: Int) -> Int:
    if n <= 0:
        n
    else:
        y3(n - 1) + 2

