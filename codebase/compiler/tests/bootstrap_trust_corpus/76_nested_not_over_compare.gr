fn cmp_lt(x: Int, y: Int) -> Bool:
    ret x < y

fn cmp_eq(x: Int, y: Int) -> Bool:
    ret x == y

fn nested_not_over_compare(a: Int, b: Int, c: Int) -> Int:
    let ab_lt = cmp_lt(a, b)
    let bc_lt = cmp_lt(b, c)
    let ac_eq = cmp_eq(a, c)
    let neg_ab = not ab_lt
    let neg_bc = not bc_lt
    let neg_eq = not ac_eq
    let strict_decreasing = neg_ab and neg_bc
    let any_diff = neg_eq
    let twice_negated = not (not strict_decreasing)
    if twice_negated and any_diff:
        ret 1
    else:
        if twice_negated or any_diff:
            ret 2
        else:
            ret 0

fn nested_not_driver(a: Int, b: Int, c: Int) -> Int:
    let result1 = nested_not_over_compare(a, b, c)
    let result2 = nested_not_over_compare(c, b, a)
    ret result1 + result2
