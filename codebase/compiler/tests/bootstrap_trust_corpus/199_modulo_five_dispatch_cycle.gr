// Slot 199 — Modulo-five dispatch recursive descent into a 5-way
// mutual call cycle.
// Stresses: recursive descent where each step computes both quotient
// and remainder via `/` and `%`, then dispatches to one of five
// mutually-recursive helpers based on the remainder mod 5. Extends
// #637 slot 194 (3-way `% 3` dispatch) to a 5-way `% 5` dispatch with
// a wider mutual-recursion fan.

fn five_a(n: Int, acc: Int) -> Int:
    if n <= 0:
        acc
    else:
        let q = n / 5
        let r = n % 5
        if r == 0:
            five_b(q, acc + n)
        else:
            if r == 1:
                five_c(q, acc + n - 1)
            else:
                if r == 2:
                    five_d(q, acc + n - 2)
                else:
                    if r == 3:
                        five_e(q, acc + n - 3)
                    else:
                        five_a(q, acc + n - 4)

fn five_b(n: Int, acc: Int) -> Int:
    if n <= 0:
        acc + 1
    else:
        let q = n / 5
        let r = n % 5
        if r == 0:
            five_c(q, acc + 2)
        else:
            if r == 1:
                five_d(q, acc + 3)
            else:
                if r == 2:
                    five_e(q, acc + 5)
                else:
                    if r == 3:
                        five_a(q, acc + 7)
                    else:
                        five_b(q, acc + 11)

fn five_c(n: Int, acc: Int) -> Int:
    if n <= 0:
        acc - 1
    else:
        let q = n / 5
        let r = n % 5
        if r == 0:
            five_d(q, acc + 13)
        else:
            if r == 1:
                five_e(q, acc + 17)
            else:
                if r == 2:
                    five_a(q, acc + 19)
                else:
                    if r == 3:
                        five_b(q, acc + 23)
                    else:
                        five_c(q, acc + 29)

fn five_d(n: Int, acc: Int) -> Int:
    if n <= 0:
        acc + 2
    else:
        let q = n / 5
        let r = n % 5
        if r == 0:
            five_e(q, acc + 31)
        else:
            if r == 1:
                five_a(q, acc + 37)
            else:
                if r == 2:
                    five_b(q, acc + 41)
                else:
                    if r == 3:
                        five_c(q, acc + 43)
                    else:
                        five_d(q, acc + 47)

fn five_e(n: Int, acc: Int) -> Int:
    if n <= 0:
        acc - 2
    else:
        let q = n / 5
        let r = n % 5
        if r == 0:
            five_a(q, acc + 53)
        else:
            if r == 1:
                five_b(q, acc + 59)
            else:
                if r == 2:
                    five_c(q, acc + 61)
                else:
                    if r == 3:
                        five_d(q, acc + 67)
                    else:
                        five_e(q, acc + 71)

fn main() -> Int:
    five_a(120, 0)
