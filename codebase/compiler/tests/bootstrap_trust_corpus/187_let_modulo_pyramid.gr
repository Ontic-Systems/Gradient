// Slot 187 — 7-deep let pyramid with cross-binding modulo and recursive call.
// Stresses: deep nested let chain where each level combines modulo of prior
// bindings with the result of a recursive call.

fn step(n: Int) -> Int:
    if n <= 0:
        0
    else:
        n + step(n - 1)

fn modulo_pyramid(a: Int) -> Int:
    let l1 = a + 1
    let l2 = l1 % 5
    let l3 = step(l1) + l2
    let l4 = l3 % 7
    let l5 = step(l2) + l4
    let l6 = l3 + l5 - l4 % 3
    let l7 = l1 + l2 + l3 + l4 + l5 + l6 % 11
    let l8 = step(l4) + l7
    l8

fn main() -> Int:
    modulo_pyramid(8)
