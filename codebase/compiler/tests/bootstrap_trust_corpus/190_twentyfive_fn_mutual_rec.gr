// Slot 190 — Twenty-five-function mutual recursion cycle.
// Stresses: a single cycle of 25 mutually recursive functions, each
// dispatching to the next via modulo, with a guard arm terminating at
// `n <= 0`. Confirms the Rust kernel's recursion-tracking budget still
// admits a 25-wide cycle, one step beyond #520's slot 185 (24-fn).

fn step25_a(n: Int) -> Int:
    if n <= 0:
        0
    else:
        step25_b(n - 1) + 1

