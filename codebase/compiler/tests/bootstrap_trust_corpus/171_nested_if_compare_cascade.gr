// Slot 171 — Deeply nested if-cascade dispatch via cascading comparisons.
// Stresses: 5-deep nested if-elif chain producing distinct integer payloads,
// plus a Bool-derived top-level dispatch.

fn classify(n: Int) -> Int:
    if n < -50:
        if n < -200:
            -4
        else:
            if n < -100:
                -3
            else:
                -2
    else:
        if n <= 0:
            if n == 0:
                0
            else:
                if n < -10:
                    -1
                else:
                    1
        else:
            if n < 10:
                2
            else:
                if n < 50:
                    3
                else:
                    if n < 200:
                        4
                    else:
                        5

fn either_extreme(a: Int, b: Int) -> Bool:
    let lo = a < -100
    let hi = b > 100
    lo or hi

fn cascade(a: Int, b: Int) -> Int:
    let pa = classify(a)
    let pb = classify(b)
    if either_extreme(a, b):
        pa - pb
    else:
        if pa == pb:
            pa + pa
        else:
            pa + pb

fn main() -> Int:
    cascade(73, -150) + cascade(0, 5)
