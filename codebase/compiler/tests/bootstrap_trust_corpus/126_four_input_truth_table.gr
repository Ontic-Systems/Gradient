// Slot 126 — 4-input boolean truth table via nested if/else dispatch.
// Stresses: 4-arg Bool inputs feeding deep nested if-tree returning distinct ints per branch.

fn dispatch4(a: Bool, b: Bool, c: Bool, d: Bool) -> Int:
    if a:
        if b:
            if c:
                if d:
                    15
                else:
                    14
            else:
                if d:
                    13
                else:
                    12
        else:
            if c:
                if d:
                    11
                else:
                    10
            else:
                if d:
                    9
                else:
                    8
    else:
        if b:
            if c:
                if d:
                    7
                else:
                    6
            else:
                if d:
                    5
                else:
                    4
        else:
            if c:
                if d:
                    3
                else:
                    2
            else:
                if d:
                    1
                else:
                    0

fn main(a: Bool, b: Bool, c: Bool, d: Bool) -> Int:
    dispatch4(a, b, c, d)
