// Slot 130 — 13-function mutual-recursion cycle (NEW widest).
// Stresses: 13-fn termination via decreasing argument; beats slot 125's 12-fn.

fn s1(n: Int) -> Int:
    if n <= 0:
        0
    else:
        s2(n - 1)

fn s2(n: Int) -> Int:
    if n <= 0:
        0
    else:
        s3(n - 1) + 1

fn s3(n: Int) -> Int:
    if n <= 0:
        0
    else:
        s4(n - 1)

fn s4(n: Int) -> Int:
    if n <= 0:
        0
    else:
        s5(n - 1) + 1

