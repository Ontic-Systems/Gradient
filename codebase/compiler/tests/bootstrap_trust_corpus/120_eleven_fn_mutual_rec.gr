// Slot 120 — 11-function mutual-recursion cycle (NEW widest).
// Stresses: 11-fn termination via decreasing argument; beats slot 115's 10-fn.

fn m1(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m2(n - 1)

fn m2(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m3(n - 1) + 1

fn m3(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m4(n - 1)

fn m4(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m5(n - 1) + 1

fn m5(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m6(n - 1)

fn m6(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m7(n - 1) + 1

fn m7(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m8(n - 1)

fn m8(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m9(n - 1) + 1

fn m9(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m10(n - 1)

fn m10(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m11(n - 1) + 1

fn m11(n: Int) -> Int:
    if n <= 0:
        0
    else:
        m1(n - 1)

fn main(n: Int) -> Int:
    m1(n)
