// Slot 195 — Twenty-six-function mutual recursion cycle.
// Stresses: a single cycle of 26 mutually recursive functions, each
// dispatching to the next via a guarded descent. Confirms the Rust
// kernel's recursion-tracking budget still admits a 26-wide cycle,
// one step beyond #637's slot 190 (25-fn).

fn step26_a(n: Int) -> Int:
    if n <= 0:
        0
    else:
        step26_b(n - 1) + 1

