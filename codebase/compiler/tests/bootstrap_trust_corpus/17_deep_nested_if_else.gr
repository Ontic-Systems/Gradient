fn classify(n: Int) -> Int:
    if n < 0:
        if n < -10:
            ret -2
        else:
            ret -1
    else:
        if n == 0:
            ret 0
        else:
            if n < 10:
                ret 1
            else:
                if n < 100:
                    ret 2
                else:
                    ret 3

fn sign_band(x: Int, lo: Int, hi: Int) -> Int:
    if x < lo:
        ret -1
    else:
        if x > hi:
            ret 1
        else:
            ret 0
