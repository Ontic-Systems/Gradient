// Slot 185 — Twenty-four-function mutual-recursion cycle.
// Stresses: widest mutual recursion, extending slot 180's 23-function cycle.

fn s1(n: Int) -> Int:
    if n <= 0:
        n
    else:
        s2(n - 1) + 1

