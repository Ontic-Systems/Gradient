// Slot 150 — Seventeen-function mutual-recursion cycle.
// Stresses: widest mutual recursion so far, extending slot 145's 16-function cycle.

fn v1(n: Int) -> Int:
    if n <= 0:
        n
    else:
        v2(n - 1) + 1

fn v2(n: Int) -> Int:
    if n <= 0:
        n
    else:
        v3(n - 1) + 2

fn v3(n: Int) -> Int:
    if n <= 0:
        n
    else:
        v4(n - 1) + 3

