fn v15(n: Int) -> Int:
    if n <= 0:
        n
    else:
        v16(n - 1) + 15

fn v16(n: Int) -> Int:
    if n <= 0:
        n
    else:
        v17(n - 1) + 16

fn v17(n: Int) -> Int:
    if n <= 0:
        n
    else:
        v1(n - 1) + 17

fn main() -> Int:
    v1(17)
