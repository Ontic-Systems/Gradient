// Slot 160 — Nineteen-function mutual-recursion cycle.
// Stresses: widest mutual recursion so far, extending slot 155's 18-function cycle.

fn x1(n: Int) -> Int:
    if n <= 0:
        n
    else:
        x2(n - 1) + 1

fn x2(n: Int) -> Int:
    if n <= 0:
        n
    else:
        x3(n - 1) + 2

