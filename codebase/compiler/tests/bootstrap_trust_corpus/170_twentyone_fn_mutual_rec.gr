// Slot 170 — Twenty-one-function mutual-recursion cycle.
// Stresses: widest mutual recursion so far, extending slot 165's 20-function cycle.

fn z1(n: Int) -> Int:
    if n <= 0:
        n
    else:
        z2(n - 1) + 1

fn z2(n: Int) -> Int:
    if n <= 0:
        n
    else:
        z3(n - 1) + 2

