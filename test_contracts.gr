@requires(n >= 0)
@ensures(result >= 0)
fn abs(n: i32) -> i32:
    if n < 0:
        ret 0 - n
    else:
        ret n

@requires(n > 0)
@ensures(result > 1)
fn factorial(n: i32) -> i32:
    if n <= 1:
        ret 1
    else:
        ret n * factorial(n - 1)

fn main():
    let x = abs(-5)
    let f = factorial(5)
