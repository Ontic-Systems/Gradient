/// Token Module for Gradient Self-Hosting Compiler
///
/// This module defines the token types needed for lexical analysis.
/// It's the foundation of the compiler frontend.

mod token:

    // =========================================================================
    // Position and Span
    // =========================================================================

    /// Position in source file (line, column, byte offset)
    type Position:
        line: Int
        col: Int
        offset: Int

    /// Range of positions in source file
    type Span:
        file_id: Int
        start: Position
        end: Position

    // =========================================================================
    // Token Kinds
    // =========================================================================

    /// All possible token types in the Gradient language
    enum TokenKind:
        // Literals
        IntLit(value: Int)
        FloatLit(value: Float)
        StringLit(value: String)
        BoolLit(value: Bool)

        // Keywords
        Fn
        Let
        Mut
        If
        Else
        For
        In
        While
        Ret
        Type
        Mod
        Use
        Impl
        Match
        True
        False
        And
        Or
        Not
        Comptime
        Trait
        Actor
        State
        On
        Spawn
        Send
        Ask
        As
        Break
        Continue
        Defer
        Extern
        Export
        Pub

        // Structured concurrency and supervision
        ConcurrentScope
        Supervisor
        Strategy
        Restart
        MaxRestarts
        Child
        OneForOne
        OneForAll
        RestForOne
        Permanent
        Transient
        Temporary

        // Capability keywords (Pony-style)
        Iso
        Val
        Ref
        Box
        Trn
        Tag

        // Operators
        Plus        // +
        Minus       // -
        Star        // *
        Slash       // /
        Percent     // %
        Bang        // !
        Ampersand   // &
        Caret       // ^
        Tilde       // ~
        At          // @
        Hash        // #
        Dollar      // $
        Eq          // ==
        Ne          // !=
        Lt          // <
        Le          // <=
        Gt          // >
        Ge          // >=
        AndAnd      // &&
        OrOr        // ||
        NotNot      // !! (logical not, though rarely used)
        Assign      // =
        PlusAssign  // +=
        MinusAssign // -=
        StarAssign  // *=
        SlashAssign // /=
        PercentAssign // %=
        LtLt        // <<
        GtGt        // >>
        Arrow       // ->
        FatArrow    // =>
        Pipe        // |
        Dot         // .
        DotDot      // ..
        DotDotEq    // ..=
        ColonColon  // ::
        Question    // ?
        Underscore  // _

        // Delimiters
        LParen      // (
        RParen      // )
        LBracket    // [
        RBracket    // ]
        LBrace      // {
        RBrace      // }
        Colon       // :
        Comma       // ,
        Semi        // ;

        // Special
        Ident(name: String)
        Indent
        Dedent
        Newline
        Eof
        Error(message: String)

    // =========================================================================
    // Token
    // =========================================================================

    /// A single lexical token with its source location
    type Token:
        kind: TokenKind
        span: Span

    // =========================================================================
    // Constructors
    // =========================================================================

    /// Create a new token with the given kind and span
    fn new(kind: TokenKind, span: Span) -> !{Heap} Token:
        ret Token { kind: kind, span: span }

    /// Create an EOF token at the given position
    fn eof(file_id: Int, pos: Position) -> !{Heap} Token:
        let span = Span { file_id: file_id, start: pos, end: pos }
        ret Token { kind: Eof, span: span }

    /// Create an error token with a message
    fn error(message: String, span: Span) -> !{Heap} Token:
        let err_kind = Error(message)
        ret Token { kind: err_kind, span: span }

    // =========================================================================
    // Predicates
    // =========================================================================

    /// Check if token is a literal
    fn is_literal(kind: TokenKind) -> Bool:
        match kind:
            IntLit(_):
                ret true
            FloatLit(_):
                ret true
            StringLit(_):
                ret true
            BoolLit(_):
                ret true
            _:
                ret false

    /// Check if token is a keyword
    fn is_keyword(kind: TokenKind) -> Bool:
        match kind:
            Fn:
                ret true
            Let:
                ret true
            Mut:
                ret true
            If:
                ret true
            Else:
                ret true
            For:
                ret true
            While:
                ret true
            Ret:
                ret true
            Type:
                ret true
            Mod:
                ret true
            Use:
                ret true
            Impl:
                ret true
            Match:
                ret true
            True:
                ret true
            False:
                ret true
            And:
                ret true
            Or:
                ret true
            Not:
                ret true
            Comptime:
                ret true
            Trait:
                ret true
            Actor:
                ret true
            State:
                ret true
            On:
                ret true
            Spawn:
                ret true
            Send:
                ret true
            Ask:
                ret true
            As:
                ret true
            Break:
                ret true
            Continue:
                ret true
            Defer:
                ret true
            Extern:
                ret true
            Export:
                ret true
            Pub:
                ret true
            Iso:
                ret true
            Val:
                ret true
            Ref:
                ret true
            Box:
                ret true
            Trn:
                ret true
            Tag:
                ret true
            ConcurrentScope:
                ret true
            Supervisor:
                ret true
            Strategy:
                ret true
            Restart:
                ret true
            MaxRestarts:
                ret true
            Child:
                ret true
            OneForOne:
                ret true
            OneForAll:
                ret true
            RestForOne:
                ret true
            Permanent:
                ret true
            Transient:
                ret true
            Temporary:
                ret true
            _:
                ret false

    /// Check if token is an operator
    fn is_operator(kind: TokenKind) -> Bool:
        match kind:
            Plus:
                ret true
            Minus:
                ret true
            Star:
                ret true
            Slash:
                ret true
            Percent:
                ret true
            Bang:
                ret true
            Ampersand:
                ret true
            Caret:
                ret true
            Tilde:
                ret true
            Eq:
                ret true
            Ne:
                ret true
            Lt:
                ret true
            Le:
                ret true
            Gt:
                ret true
            Ge:
                ret true
            AndAnd:
                ret true
            OrOr:
                ret true
            NotNot:
                ret true
            Assign:
                ret true
            PlusAssign:
                ret true
            MinusAssign:
                ret true
            StarAssign:
                ret true
            SlashAssign:
                ret true
            PercentAssign:
                ret true
            LtLt:
                ret true
            GtGt:
                ret true
            Arrow:
                ret true
            FatArrow:
                ret true
            Pipe:
                ret true
            Dot:
                ret true
            DotDot:
                ret true
            DotDotEq:
                ret true
            ColonColon:
                ret true
            Question:
                ret true
            _:
                ret false

    /// Check if token is a delimiter
    fn is_delimiter(kind: TokenKind) -> Bool:
        match kind:
            LParen:
                ret true
            RParen:
                ret true
            LBracket:
                ret true
            RBracket:
                ret true
            LBrace:
                ret true
            RBrace:
                ret true
            Colon:
                ret true
            Comma:
                ret true
            Semi:
                ret true
            _:
                ret false

    /// Check if token is an identifier
    fn is_identifier(kind: TokenKind) -> Bool:
        match kind:
            Ident(_):
                ret true
            _:
                ret false

    // =========================================================================
    // Display Helpers
    // =========================================================================

    /// Get a human-readable name for a token kind
    fn kind_name(kind: TokenKind) -> String:
        match kind:
            IntLit(_):
                ret "integer literal"
            FloatLit(_):
                ret "float literal"
            StringLit(_):
                ret "string literal"
            BoolLit(_):
                ret "boolean literal"
            Fn:
                ret "'fn'"
            Let:
                ret "'let'"
            Mut:
                ret "'mut'"
            If:
                ret "'if'"
            Else:
                ret "'else'"
            For:
                ret "'for'"
            In:
                ret "'in'"
            While:
                ret "'while'"
            Ret:
                ret "'ret'"
            Type:
                ret "'type'"
            Mod:
                ret "'mod'"
            Use:
                ret "'use'"
            Impl:
                ret "'impl'"
            Match:
                ret "'match'"
            True:
                ret "'true'"
            False:
                ret "'false'"
            And:
                ret "'and'"
            Or:
                ret "'or'"
            Not:
                ret "'not'"
            Comptime:
                ret "'comptime'"
            Trait:
                ret "'trait'"
            Actor:
                ret "'actor'"
            State:
                ret "'state'"
            On:
                ret "'on'"
            Spawn:
                ret "'spawn'"
            Send:
                ret "'send'"
            Ask:
                ret "'ask'"
            As:
                ret "'as'"
            Break:
                ret "'break'"
            Continue:
                ret "'continue'"
            Defer:
                ret "'defer'"
            Extern:
                ret "'extern'"
            Export:
                ret "'export'"
            Pub:
                ret "'pub'"
            Iso:
                ret "'iso'"
            Val:
                ret "'val'"
            Ref:
                ret "'ref'"
            Box:
                ret "'box'"
            Trn:
                ret "'trn'"
            Tag:
                ret "'tag'"
            Plus:
                ret "plus"
            Minus:
                ret "minus"
            Star:
                ret "star"
            Slash:
                ret "slash"
            Percent:
                ret "percent"
            Bang:
                ret "bang"
            Ampersand:
                ret "ampersand"
            Caret:
                ret "caret"
            Tilde:
                ret "tilde"
            At:
                ret "'@'"
            Hash:
                ret "'#'"
            Dollar:
                ret "'$'"
            Eq:
                ret "'=='"
            Ne:
                ret "'!='"
            Lt:
                ret "lt"
            Le:
                ret "'<='"
            Gt:
                ret "gt"
            Ge:
                ret "'>='"
            AndAnd:
                ret "'&&'"
            OrOr:
                ret "'||'"
            NotNot:
                ret "'!!'"
            PlusAssign:
                ret "'+='"
            MinusAssign:
                ret "'-='"
            StarAssign:
                ret "'*='"
            SlashAssign:
                ret "'/='"
            PercentAssign:
                ret "'%='"
            LtLt:
                ret "'<<'"
            GtGt:
                ret "'>>'"
            Assign:
                ret "eq"
            Arrow:
                ret "'->'"
            FatArrow:
                ret "'=>'"
            Pipe:
                ret "pipe"
            Dot:
                ret "dot"
            DotDot:
                ret "'..'"
            DotDotEq:
                ret "'..='"
            ColonColon:
                ret "'::'"
            Question:
                ret "question"
            Underscore:
                ret "underscore"
            LParen:
                ret "lparen"
            RParen:
                ret "rparen"
            LBracket:
                ret "lbracket"
            RBracket:
                ret "rbracket"
            LBrace:
                ret "lbrace"
            RBrace:
                ret "rbrace"
            Colon:
                ret "colon"
            Comma:
                ret "comma"
            Semi:
                ret "semi"
            Ident(_):
                ret "identifier"
            Indent:
                ret "INDENT"
            Dedent:
                ret "DEDENT"
            Newline:
                ret "NEWLINE"
            Eof:
                ret "EOF"
            Error(_):
                ret "ERROR"
            ConcurrentScope:
                ret "'concurrent_scope'"
            Supervisor:
                ret "'supervisor'"
            Strategy:
                ret "'strategy'"
            Restart:
                ret "'restart'"
            MaxRestarts:
                ret "'max_restarts'"
            Child:
                ret "'child'"
            OneForOne:
                ret "'one_for_one'"
            OneForAll:
                ret "'one_for_all'"
            RestForOne:
                ret "'rest_for_one'"
            Permanent:
                ret "'permanent'"
            Transient:
                ret "'transient'"
            Temporary:
                ret "'temporary'"

    /// Format a position as "line:col"
    fn format_position(pos: Position) -> !{Heap} String:
        let sb = stringbuilder_new()
        stringbuilder_append_int(sb, pos.line)
        stringbuilder_append_char(sb, 58)  // ':'
        stringbuilder_append_int(sb, pos.col)
        ret stringbuilder_to_string(sb)

    /// Format a span as "file_id:start_line:start_col-end_line:end_col"
    fn format_span(span: Span) -> !{Heap} String:
        let sb = stringbuilder_new()
        stringbuilder_append_int(sb, span.file_id)
        stringbuilder_append_char(sb, 58)  // ':'
        let start_str = format_position(span.start)
        stringbuilder_append(sb, start_str)
        stringbuilder_append_char(sb, 45)  // '-'
        let end_str = format_position(span.end)
        stringbuilder_append(sb, end_str)
        ret stringbuilder_to_string(sb)

    /// Format a token for display (for error messages)
    fn format_token(tok: Token) -> !{Heap} String:
        let sb = stringbuilder_new()
        stringbuilder_append_char(sb, 91)   // '['
        let span_str = format_span(tok.span)
        stringbuilder_append(sb, span_str)
        stringbuilder_append_char(sb, 93)   // ']'
        stringbuilder_append_char(sb, 32)   // ' '
        let kind_str = kind_name(tok.kind)
        stringbuilder_append(sb, kind_str)
        ret stringbuilder_to_string(sb)

    // =========================================================================
    // Keyword Lookup
    // =========================================================================

    /// Check if a string is a keyword and return the corresponding TokenKind
    /// Returns None if the string is not a keyword
    fn lookup_keyword(name: String) -> Option[TokenKind]:
        if name == "fn":
            ret Some(Fn)
        if name == "let":
            ret Some(Let)
        if name == "mut":
            ret Some(Mut)
        if name == "if":
            ret Some(If)
        if name == "else":
            ret Some(Else)
        if name == "for":
            ret Some(For)
        if name == "in":
            ret Some(In)
        if name == "while":
            ret Some(While)
        if name == "ret":
            ret Some(Ret)
        if name == "type":
            ret Some(Type)
        if name == "mod":
            ret Some(Mod)
        if name == "use":
            ret Some(Use)
        if name == "impl":
            ret Some(Impl)
        if name == "match":
            ret Some(Match)
        if name == "true":
            ret Some(True)
        if name == "false":
            ret Some(False)
        if name == "and":
            ret Some(And)
        if name == "or":
            ret Some(Or)
        if name == "not":
            ret Some(Not)
        if name == "comptime":
            ret Some(Comptime)
        if name == "trait":
            ret Some(Trait)
        if name == "actor":
            ret Some(Actor)
        if name == "state":
            ret Some(State)
        if name == "on":
            ret Some(On)
        if name == "spawn":
            ret Some(Spawn)
        if name == "send":
            ret Some(Send)
        if name == "ask":
            ret Some(Ask)
        if name == "as":
            ret Some(As)
        if name == "break":
            ret Some(Break)
        if name == "continue":
            ret Some(Continue)
        if name == "defer":
            ret Some(Defer)
        if name == "extern":
            ret Some(Extern)
        if name == "export":
            ret Some(Export)
        if name == "pub":
            ret Some(Pub)
        if name == "iso":
            ret Some(Iso)
        if name == "val":
            ret Some(Val)
        if name == "ref":
            ret Some(Ref)
        if name == "box":
            ret Some(Box)
        if name == "trn":
            ret Some(Trn)
        if name == "tag":
            ret Some(Tag)
        ret None
