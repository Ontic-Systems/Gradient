mod compiler:

    type Token:
        dummy: Int

    type Ast:
        dummy: Int

    type Ir:
        dummy: Int

    type Compiler:
        stage: Int

    fn new_compiler() -> Compiler:
        ret Compiler { stage: 0 }

    fn compile_string(c: Compiler, source: String) -> (Compiler, String):
        ret (c, "compiled")

    fn compile_file(c: Compiler, path: String) -> (Compiler, String):
        ret (c, "compiled")
