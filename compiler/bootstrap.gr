mod bootstrap:

    type Compiler:
        dummy: Int

    fn new_compiler() -> Compiler:
        ret Compiler { dummy: 0 }

    fn compile_source(c: Compiler, source: String) -> (Compiler, String):
        ret (c, "success")

    fn bootstrap_compile(source: String) -> String:
        let c = new_compiler()
        let result_pair = compile_source(c, source)
        ret "success"
