/// Type Checker Module for Gradient Self-Hosting Compiler
///
/// This module implements Hindley-Milner type inference with extensions for
/// effects, capabilities, and comptime evaluation. It's the heart of the
/// Gradient type system.

mod checker:

    // =========================================================================
    // Imports (would reference types module)
    // =========================================================================
    // use types.{Ty, TyRef, Capability, EffectSet, FnSig, TypeParam}

    // =========================================================================
    // Type Error Types
    // =========================================================================

    /// All possible type errors that can occur during type checking
    enum TypeError:
        // Type mismatches
        TypeMismatch(expected: Int, found: Int, context: String)
        TypeMismatchWithContext(expected: Int, found: Int, context: String, span: Span)

        // Unification errors
        OccursCheckFailed(var_id: Int, ty: Int)
        CannotUnify(t1: Int, t2: Int)

        // Name resolution errors
        UndefinedVariable(name: String)
        UndefinedFunction(name: String)
        UndefinedType(name: String)
        AmbiguousName(name: String)

        // Effect errors
        EffectMismatch(declared: Int, actual: Int)
        MissingEffect(effect: String, context: String)
        UnexpectedEffect(effect: String, context: String)

        // Capability errors
        InvalidCapability(cap: Capability, reason: String)
        CapabilityMismatch(expected: Capability, found: Capability)
        SendabilityViolation(ty: Int)

        // Generic errors
        WrongNumberOfTypeArgs(name: String, expected: Int, found: Int)
        WrongNumberOfArgs(name: String, expected: Int, found: Int)

        // Feature errors
        ComptimeEvaluationFailed(expr: String, reason: String)
        UnsupportedFeature(feature: String)

        // Pattern errors
        NonExhaustiveMatch(missing: List[String])
        PatternTypeMismatch(pattern: String, expected: Int, found: Int)

    /// Source location for error reporting
    type Span:
        file_id: Int
        start_line: Int
        start_col: Int
        end_line: Int
        end_col: Int

    /// Severity level for errors/warnings
    enum Severity:
        Error
        Warning
        Note

    // =========================================================================
    // Type Environment
    // =========================================================================

    /// A binding in the environment - represents a variable or function
    type Binding:
        name: String
        ty: Int  // TyRef index
        mutable: Bool
        comptime: Bool
        consumed: Bool  // For linear types
        span: Span

    /// Scope level for tracking variable lifetimes
    type Scope:
        bindings: List[Binding]
        parent: Option[ScopeRef]
        level: Int  // Nesting depth

    /// Reference to a scope
    type ScopeRef:
        idx: Int

    /// Type definition in the environment
    type TypeDef:
        name: String
        params: List[String]  // Type parameter names
        definition: Int  // TyRef index
        is_builtin: Bool
        span: Span

    /// Function definition in the environment
    type FnDef:
        name: String
        sig: Int  // FnSig reference
        is_comptime: Bool
        is_extern: Bool
        body_checked: Bool
        span: Span

    /// The complete type checking environment
    type TypeEnv:
        // Current scope chain
        current_scope: ScopeRef
        scopes: List[Scope]

        // Global definitions
        types: List[TypeDef]  // Type definitions
        functions: List[FnDef]  // Function definitions

        // Type variable management (Hindley-Milner)
        next_var_id: Int
        substitutions: List[Option[Int]]  // VarId -> TyRef mapping

        // Error collection
        errors: List[TypeError]
        warnings: List[TypeError]

        // Effect context
        current_effects: Int  // EffectSet reference

    // =========================================================================
    // Type Checker State
    // =========================================================================

    /// The main type checker structure
    type TypeChecker:
        env: TypeEnv
        current_function: Option[FnDef]
        return_type: Option[Int]  // Expected return type
        in_comptime_context: Bool

    /// Result of type checking an expression
    type CheckResult:
        ty: Int  // The inferred type
        effects: Int  // Effects performed
        errors: List[TypeError]

    // =========================================================================
    // Core Type Checking Functions
    // =========================================================================

    /// Create a new type checker
    fn new_checker() -> TypeChecker:
        let env = TypeEnv:
            current_scope: make_scope_ref(0)
            scopes: [make_empty_scope()]
            types: []
            functions: []
            next_var_id: 0
            substitutions: []
            errors: []
            warnings: []
            current_effects: 0

        TypeChecker:
            env: env
            current_function: Option[FnDef]: None
            return_type: Option[Int]: None
            in_comptime_context: false

    /// Type check a complete module
    fn check_module(checker: TypeChecker, module_ast: Int) -> TypeChecker:
        // First pass: collect all type and function definitions
        let checker = collect_definitions(checker, module_ast)

        // Second pass: check function bodies
        let checker = check_function_bodies(checker, module_ast)

        checker

    /// Collect top-level definitions
    fn collect_definitions(checker: TypeChecker, module_ast: Int) -> TypeChecker:
        // Simplified - would iterate through module items
        // and add types/functions to environment
        checker

    /// Check all function bodies
    fn check_function_bodies(checker: TypeChecker, module_ast: Int) -> TypeChecker:
        // Simplified - would iterate through functions
        // and check each body
        checker

    // =========================================================================
    // Expression Type Checking
    // =========================================================================

    /// Check an expression and return its type
    fn check_expr(checker: TypeChecker, expr: Int) -> (TypeChecker, CheckResult):
        // Simplified - would dispatch to specific check functions
        // based on expression kind

        let result = CheckResult:
            ty: 0  // Would be Ty::Unknown
            effects: 0  // Would be EffectSet::pure
            errors: []

        (checker, result)

    /// Check an integer literal
    fn check_int_lit(checker: TypeChecker, value: Int) -> (TypeChecker, CheckResult):
        // Integer literals default to I32 but can be widened
        let result = CheckResult:
            ty: 1  // Would be Ty::I32
            effects: 0  // Pure
            errors: []

        (checker, result)

    /// Check a variable reference
    fn check_var_ref(checker: TypeChecker, name: String) -> (TypeChecker, CheckResult):
        match lookup_binding(checker.env, name):
            Some(binding):
                let result = CheckResult:
                    ty: binding.ty
                    effects: 0  // Pure
                    errors: []
                (checker, result)
            None:
                let error = TypeError:
                    UndefinedVariable(name: name)
                let env = add_error(checker.env, error)
                let checker = TypeChecker:
                    env: env
                    current_function: checker.current_function
                    return_type: checker.return_type
                    in_comptime_context: checker.in_comptime_context
                let result = CheckResult:
                    ty: 0  // Unknown
                    effects: 0
                    errors: [error]
                (checker, result)

    /// Check a binary operation
    fn check_binary_op(checker: TypeChecker, op: BinOp, left: Int, right: Int) -> (TypeChecker, CheckResult):
        // Check both operands
        let (checker, left_result) = check_expr(checker, left)
        let (checker, right_result) = check_expr(checker, right)

        // Combine effects
        let effects = merge_effects_ref(left_result.effects, right_result.effects)

        // Determine result type based on operation
        let ty = match op:
            Add | Sub | Mul | Div | Mod:
                // Arithmetic: operands must be numeric, result is widest type
                if is_numeric(left_result.ty) and is_numeric(right_result.ty):
                    widen_types(left_result.ty, right_result.ty)
                else:
                    0  // Error case
            Eq | Ne | Lt | Le | Gt | Ge:
                // Comparison: operands must be comparable, result is Bool
                if is_comparable(left_result.ty, right_result.ty):
                    2  // Would be Ty::Bool
                else:
                    0
            And | Or:
                // Logical: operands must be Bool, result is Bool
                if is_bool(left_result.ty) and is_bool(right_result.ty):
                    2  // Ty::Bool
                else:
                    0
            _:
                0

        let result = CheckResult:
            ty: ty
            effects: effects
            errors: list_concat(left_result.errors, right_result.errors)

        (checker, result)

    /// Check a function call
    fn check_call(checker: TypeChecker, func: Int, args: List[Int]) -> (TypeChecker, CheckResult):
        // Check the function expression
        let (checker, func_result) = check_expr(checker, func)

        // Check all arguments
        let arg_results = check_args(checker, args)

        // Check function type matches arguments
        let result = match get_function_type(func_result.ty):
            Some(fn_sig):
                if list_len(fn_sig.params) == list_len(args):
                    // Check each argument against parameter
                    CheckResult:
                        ty: fn_sig.ret
                        effects: fn_sig.effects
                        errors: []
                else:
                    CheckResult:
                        ty: 0
                        effects: 0
                        errors: [TypeError:
                            WrongNumberOfArgs(
                                name: "function",
                                expected: list_len(fn_sig.params),
                                found: list_len(args)
                            )
                        ]
            None:
                CheckResult:
                    ty: 0
                    effects: 0
                    errors: [TypeError:
                        TypeMismatch(
                            expected: 99,  // Function type
                            found: func_result.ty,
                            context: "call expression"
                        )
                    ]

        (checker, result)

    /// Check a list of arguments
    fn check_args(checker: TypeChecker, args: List[Int]) -> List[CheckResult]:
        // Simplified - would check each argument
        []

    // =========================================================================
    // Statement Type Checking
    // =========================================================================

    /// Check a statement
    fn check_stmt(checker: TypeChecker, stmt: Int) -> (TypeChecker, CheckResult):
        // Simplified - would dispatch based on statement kind
        let result = CheckResult:
            ty: 0
            effects: 0
            errors: []
        (checker, result)

    /// Check a let binding
    fn check_let(checker: TypeChecker, name: String, type_ann: Option[Int], value: Int, mutable: Bool) -> (TypeChecker, CheckResult):
        // Check the value
        let (checker, value_result) = check_expr(checker, value)

        // Determine the variable type
        let ty = match type_ann:
            Some(ann):
                // Check annotation matches value
                if types_equal(ann, value_result.ty):
                    ann
                else:
                    // Type mismatch error
                    let error = TypeError:
                        TypeMismatch(
                            expected: ann,
                            found: value_result.ty,
                            context: "let binding"
                        )
                    let env = add_error(checker.env, error)
                    let checker = TypeChecker:
                        env: env
                        current_function: checker.current_function
                        return_type: checker.return_type
                        in_comptime_context: checker.in_comptime_context
                    ann  // Use annotation anyway
            None:
                value_result.ty  // Infer from value

        // Add binding to environment
        let binding = Binding:
            name: name
            ty: ty
            mutable: mutable
            comptime: checker.in_comptime_context
            consumed: false
            span: make_empty_span()

        let env = add_binding(checker.env, binding)
        let checker = TypeChecker:
            env: env
            current_function: checker.current_function
            return_type: checker.return_type
            in_comptime_context: checker.in_comptime_context

        let result = CheckResult:
            ty: ty
            effects: value_result.effects
            errors: value_result.errors

        (checker, result)

    /// Check an assignment
    fn check_assign(checker: TypeChecker, target: Int, value: Int) -> (TypeChecker, CheckResult):
        // Check the value
        let (checker, value_result) = check_expr(checker, value)

        // Check target is assignable
        // (simplified - would verify target is a mutable variable)

        let result = CheckResult:
            ty: 0  // Unit
            effects: value_result.effects
            errors: value_result.errors

        (checker, result)

    /// Check a return statement
    fn check_return(checker: TypeChecker, value: Option[Int]) -> (TypeChecker, CheckResult):
        match value:
            Some(v):
                let (checker, value_result) = check_expr(checker, v)

                // Check against expected return type
                match checker.return_type:
                    Some(expected):
                        if types_equal(expected, value_result.ty):
                            let result = CheckResult:
                                ty: 0  // Never (diverges)
                                effects: value_result.effects
                                errors: value_result.errors
                            (checker, result)
                        else:
                            let error = TypeError:
                                TypeMismatch(
                                    expected: expected,
                                    found: value_result.ty,
                                    context: "return statement"
                                )
                            let env = add_error(checker.env, error)
                            let checker = TypeChecker:
                                env: env
                                current_function: checker.current_function
                                return_type: checker.return_type
                                in_comptime_context: checker.in_comptime_context
                            let result = CheckResult:
                                ty: 0
                                effects: value_result.effects
                                errors: list_concat(value_result.errors, [error])
                            (checker, result)
                    None:
                        // Return in void function with value
                        let error = TypeError:
                            TypeMismatch(
                                expected: 0,  // Unit
                                found: value_result.ty,
                                context: "return in void function"
                            )
                        let env = add_error(checker.env, error)
                        let checker = TypeChecker:
                            env: env
                            current_function: checker.current_function
                            return_type: checker.return_type
                            in_comptime_context: checker.in_comptime_context
                        let result = CheckResult:
                            ty: 0
                            effects: value_result.effects
                            errors: list_concat(value_result.errors, [error])
                        (checker, result)
            None:
                // Void return
                let result = CheckResult:
                    ty: 0  // Unit
                    effects: 0
                    errors: []
                (checker, result)

    // =========================================================================
    // Function Type Checking
    // =========================================================================

    /// Check a function definition
    fn check_fn_def(checker: TypeChecker, name: String, params: List[ParamInfo], ret_type: Option[Int], effects: Int, body: Int) -> (TypeChecker, List[TypeError]):
        // Create new scope for function
        let checker = push_scope(checker)

        // Add parameters to scope
        let checker = add_params_to_scope(checker, params)

        // Set expected return type
        let expected_ret = match ret_type:
            Some(t): t
            None: 0  // Unit

        let checker = TypeChecker:
            env: checker.env
            current_function: checker.current_function
            return_type: Some(expected_ret)
            in_comptime_context: checker.in_comptime_context

        // Check function body
        let (checker, body_result) = check_expr(checker, body)

        // Pop function scope
        let checker = pop_scope(checker)

        // Check body type matches return type
        let errors = if types_equal(expected_ret, body_result.ty):
            body_result.errors
        else:
            list_concat(
                body_result.errors,
                [TypeError:
                    TypeMismatch(
                        expected: expected_ret,
                        found: body_result.ty,
                        context: "function body"
                    )
                ]
            )

        (checker, errors)

    /// Information about a function parameter
    type ParamInfo:
        name: String
        ty: Int
        comptime: Bool
        span: Span

    /// Add parameters to current scope
    fn add_params_to_scope(checker: TypeChecker, params: List[ParamInfo]) -> TypeChecker:
        // Simplified - would add each parameter as a binding
        checker

    // =========================================================================
    // Type Inference (Hindley-Milner)
    // =========================================================================

    /// Create a fresh type variable
    fn fresh_var(checker: TypeChecker) -> (TypeChecker, Int):
        let var_id = checker.env.next_var_id
        let env = TypeEnv:
            current_scope: checker.env.current_scope
            scopes: checker.env.scopes
            types: checker.env.types
            functions: checker.env.functions
            next_var_id: var_id + 1
            substitutions: checker.env.substitutions
            errors: checker.env.errors
            warnings: checker.env.warnings
            current_effects: checker.env.current_effects

        let checker = TypeChecker:
            env: env
            current_function: checker.current_function
            return_type: checker.return_type
            in_comptime_context: checker.in_comptime_context

        // Return Ty::Var(var_id)
        (checker, var_id)

    /// Unify two types, updating substitutions
    fn unify(checker: TypeChecker, t1: Int, t2: Int) -> (TypeChecker, Bool):
        // Simplified unification
        // 1. Apply current substitutions
        // 2. Check for equality
        // 3. Handle type variables
        // 4. Recurse into composite types

        if types_equal(t1, t2):
            (checker, true)
        else:
            // Check if t1 is a variable
            match is_type_var(t1):
                Some(var_id):
                    // Occurs check
                    if occurs_in(var_id, t2):
                        let error = TypeError:
                            OccursCheckFailed(var_id: var_id, ty: t2)
                        let env = add_error(checker.env, error)
                        let checker = TypeChecker:
                            env: env
                            current_function: checker.current_function
                            return_type: checker.return_type
                            in_comptime_context: checker.in_comptime_context
                        (checker, false)
                    else:
                        // Add substitution
                        let env = add_substitution(checker.env, var_id, t2)
                        let checker = TypeChecker:
                            env: env
                            current_function: checker.current_function
                            return_type: checker.return_type
                            in_comptime_context: checker.in_comptime_context
                        (checker, true)
                None:
                    // Check if t2 is a variable
                    match is_type_var(t2):
                        Some(var_id):
                            if occurs_in(var_id, t1):
                                let error = TypeError:
                                    OccursCheckFailed(var_id: var_id, ty: t1)
                                let env = add_error(checker.env, error)
                                let checker = TypeChecker:
                                    env: env
                                    current_function: checker.current_function
                                    return_type: checker.return_type
                                    in_comptime_context: checker.in_comptime_context
                                (checker, false)
                            else:
                                let env = add_substitution(checker.env, var_id, t1)
                                let checker = TypeChecker:
                                    env: env
                                    current_function: checker.current_function
                                    return_type: checker.return_type
                                    in_comptime_context: checker.in_comptime_context
                                (checker, true)
                        None:
                            // Neither is a variable - structural unification
                            (checker, false)

    /// Check if a type variable occurs in a type (occurs check)
    fn occurs_in(var_id: Int, ty: Int) -> Bool:
        // Simplified - would check if var_id appears in ty
        false

    /// Add a substitution
    fn add_substitution(env: TypeEnv, var_id: Int, ty: Int) -> TypeEnv:
        // Ensure substitutions list is long enough
        let subs = env.substitutions
        while list_len(subs) <= var_id:
            subs = list_append(subs, Option[Int]: None)

        // Set the substitution
        // subs[var_id] = Some(ty)

        TypeEnv:
            current_scope: env.current_scope
            scopes: env.scopes
            types: env.types
            functions: env.functions
            next_var_id: env.next_var_id
            substitutions: subs
            errors: env.errors
            warnings: env.warnings
            current_effects: env.current_effects

    // =========================================================================
    // Scope Management
    // =========================================================================

    /// Push a new scope
    fn push_scope(checker: TypeChecker) -> TypeChecker:
        let new_scope = Scope:
            bindings: []
            parent: Some(checker.env.current_scope)
            level: get_scope_level(checker.env, checker.env.current_scope) + 1

        let scopes = list_append(checker.env.scopes, new_scope)
        let new_scope_ref = make_scope_ref(list_len(scopes) - 1)

        let env = TypeEnv:
            current_scope: new_scope_ref
            scopes: scopes
            types: checker.env.types
            functions: checker.env.functions
            next_var_id: checker.env.next_var_id
            substitutions: checker.env.substitutions
            errors: checker.env.errors
            warnings: checker.env.warnings
            current_effects: checker.env.current_effects

        TypeChecker:
            env: env
            current_function: checker.current_function
            return_type: checker.return_type
            in_comptime_context: checker.in_comptime_context

    /// Pop the current scope
    fn pop_scope(checker: TypeChecker) -> TypeChecker:
        match get_parent_scope(checker.env, checker.env.current_scope):
            Some(parent):
                let env = TypeEnv:
                    current_scope: parent
                    scopes: checker.env.scopes
                    types: checker.env.types
                    functions: checker.env.functions
                    next_var_id: checker.env.next_var_id
                    substitutions: checker.env.substitutions
                    errors: checker.env.errors
                    warnings: checker.env.warnings
                    current_effects: checker.env.current_effects

                TypeChecker:
                    env: env
                    current_function: checker.current_function
                    return_type: checker.return_type
                    in_comptime_context: checker.in_comptime_context
            None:
                // Can't pop global scope
                checker

    /// Add a binding to the current scope
    fn add_binding(env: TypeEnv, binding: Binding) -> TypeEnv:
        // Get current scope
        let scope_idx = checker.env.current_scope.idx
        let scope = list_get(env.scopes, scope_idx)

        // Add binding
        let new_bindings = list_append(scope.bindings, binding)
        let new_scope = Scope:
            bindings: new_bindings
            parent: scope.parent
            level: scope.level

        // Update scopes list
        let new_scopes = list_replace(env.scopes, scope_idx, new_scope)

        TypeEnv:
            current_scope: env.current_scope
            scopes: new_scopes
            types: env.types
            functions: env.functions
            next_var_id: env.next_var_id
            substitutions: env.substitutions
            errors: env.errors
            warnings: env.warnings
            current_effects: env.current_effects

    /// Look up a binding by name
    fn lookup_binding(env: TypeEnv, name: String) -> Option[Binding]:
        // Search current scope and parents
        let current = list_get(env.scopes, env.current_scope.idx)

        // Check current scope
        let result = find_in_bindings(current.bindings, name)
        match result:
            Some(binding):
                result
            None:
                // Check parent scopes
                match current.parent:
                    Some(parent_ref):
                        lookup_binding_in_scope(env, parent_ref, name)
                    None:
                        Option[Binding]: None

    /// Look up binding in a specific scope
    fn lookup_binding_in_scope(env: TypeEnv, scope_ref: ScopeRef, name: String) -> Option[Binding]:
        let scope = list_get(env.scopes, scope_ref.idx)
        let result = find_in_bindings(scope.bindings, name)
        match result:
            Some(binding):
                result
            None:
                match scope.parent:
                    Some(parent_ref):
                        lookup_binding_in_scope(env, parent_ref, name)
                    None:
                        Option[Binding]: None

    /// Find a binding in a list of bindings
    fn find_in_bindings(bindings: List[Binding], name: String) -> Option[Binding]:
        let idx = 0
        let len = list_len(bindings)
        while idx < len:
            let binding = list_get(bindings, idx)
            if binding.name == name:
                return Option[Binding]: Some(binding)
            idx = idx + 1
        Option[Binding]: None

    // =========================================================================
    // Helper Functions
    // =========================================================================

    /// Make an empty scope
    fn make_empty_scope() -> Scope:
        Scope:
            bindings: []
            parent: Option[ScopeRef]: None
            level: 0

    /// Make a scope reference
    fn make_scope_ref(idx: Int) -> ScopeRef:
        ScopeRef: idx: idx

    /// Get the nesting level of a scope
    fn get_scope_level(env: TypeEnv, scope_ref: ScopeRef) -> Int:
        let scope = list_get(env.scopes, scope_ref.idx)
        scope.level

    /// Get the parent of a scope
    fn get_parent_scope(env: TypeEnv, scope_ref: ScopeRef) -> Option[ScopeRef]:
        let scope = list_get(env.scopes, scope_ref.idx)
        scope.parent

    /// Add an error to the environment
    fn add_error(env: TypeEnv, error: TypeError) -> TypeEnv:
        TypeEnv:
            current_scope: env.current_scope
            scopes: env.scopes
            types: env.types
            functions: env.functions
            next_var_id: env.next_var_id
            substitutions: env.substitutions
            errors: list_append(env.errors, error)
            warnings: env.warnings
            current_effects: env.current_effects

    /// Create an empty span
    fn make_empty_span() -> Span:
        Span:
            file_id: 0
            start_line: 0
            start_col: 0
            end_line: 0
            end_col: 0

    // =========================================================================
    // Type Utility Functions
    // =========================================================================

    /// Check if a type is numeric
    fn is_numeric(ty: Int) -> Bool:
        // Simplified - would check if ty is I8-I64, U8-U64, F32, F64
        true  // Placeholder

    /// Check if a type is Bool
    fn is_bool(ty: Int) -> Bool:
        // Simplified
        ty == 2  // Would be Ty::Bool

    /// Check if two types are comparable
    fn is_comparable(t1: Int, t2: Int) -> Bool:
        // Simplified - would check if types are compatible for comparison
        types_equal(t1, t2)

    /// Widen two numeric types to their common supertype
    fn widen_types(t1: Int, t2: Int) -> Int:
        // Simplified - would apply widening rules
